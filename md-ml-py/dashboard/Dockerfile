FROM node:22-alpine

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ARG NEXT_PUBLIC_PARTY0_URL=http://localhost:8081
ARG NEXT_PUBLIC_PARTY1_URL=http://localhost:8082
ARG NEXT_PUBLIC_DP0_URL=http://localhost:8090
ARG NEXT_PUBLIC_DP1_URL=http://localhost:8091
ARG NEXT_PUBLIC_DP2_URL=http://localhost:8092
ARG NEXT_PUBLIC_DP3_URL=http://localhost:8093

ENV NEXT_PUBLIC_PARTY0_URL=$NEXT_PUBLIC_PARTY0_URL
ENV NEXT_PUBLIC_PARTY1_URL=$NEXT_PUBLIC_PARTY1_URL
ENV NEXT_PUBLIC_DP0_URL=$NEXT_PUBLIC_DP0_URL
ENV NEXT_PUBLIC_DP1_URL=$NEXT_PUBLIC_DP1_URL
ENV NEXT_PUBLIC_DP2_URL=$NEXT_PUBLIC_DP2_URL
ENV NEXT_PUBLIC_DP3_URL=$NEXT_PUBLIC_DP3_URL
ENV NODE_ENV=production

RUN npm run build
RUN mkdir -p /data

EXPOSE 3000
CMD ["npm", "start"]
